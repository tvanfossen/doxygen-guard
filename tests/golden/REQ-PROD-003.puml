@startuml REQ-PROD-003 Over-the-Air Firmware Update
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "OTA Manager" as OTA_Manager
  participant "Comm Manager" as Comm_Manager
end box

header
  **REQ-PROD-003: Over-the-Air Firmware Update**
  //Description:// The system shall support remote firmware updates with\nintegrity verification.
  //Acceptance Criteria:// OTA completes download/flash/verify cycle. Device reports\nsuccess or failure to cloud.
  //Preconditions:// REQ-0020 (Remote Status Reporting)
end header


External --> OTA_Manager: EVENT_CLOUD_OTA_AVAILABLE\nOTA_OnUpdateAvailable()
activate OTA_Manager
== OTA_OnUpdateAvailable() ==
note right of OTA_Manager: Ota State Change
OTA_Manager --> Comm_Manager: EVENT_COMM_DOWNLOAD_START\nOTA_OnUpdateAvailable() -> Comm_DownloadFirmware()
loop http_has_data(&stream)
Comm_Manager --> OTA_Manager: EVENT_COMM_CHUNK_RECEIVED\nComm_DownloadFirmware() -> OTA_OnChunkReceived()
OTA_Manager --> OTA_Manager: EVENT_HW_FLASH_WRITE
end loop
Comm_Manager --> OTA_Manager: EVENT_COMM_DOWNLOAD_COMPLETE\nComm_DownloadFirmware() -> OTA_OnDownloadComplete()
note right of OTA_Manager: Ota Verify Crc
OTA_Manager -> Comm_Manager: Comm_SendStatus()
activate Comm_Manager
Comm_Manager --> OTA_Manager: return
deactivate Comm_Manager
OTA_Manager --> OTA_Manager: EVENT_CLOUD_OTA_RESULT

@enduml