@startuml REQ-PARSE-003 Python indent-based body detection
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "external" as external

box "System" #LightBlue
  participant "Parser" as Parser
end box

header
  **REQ-PARSE-003: Python indent-based body detection**
  //Description:// Detect Python function body extent by tracking indentation\nlevels
  //Acceptance Criteria:// Body end correctly identified for simple functions and\nmulti-line signatures and nested blocks
end header

note over Parser: find_body_end_indent()
note over Parser: find_body_end_indent()

Parser -> external: _find_body_start()
activate external
external --> Parser: return
deactivate external
loop
Parser -> external: strip()
activate external
external --> Parser: return
deactivate external
end loop

@enduml