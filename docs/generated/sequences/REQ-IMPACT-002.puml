@startuml REQ-IMPACT-002_Requirements_file_loading
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "Impact" as Impact
  participant "Config" as Config
end box

header
  **REQ-IMPACT-002: Requirements file loading**
  //Description:// Load requirements from CSV/JSON/YAML with configurable ID\nand name columns
  //Acceptance Criteria:// Requirements loaded and accessible by ID for impact report\nand participant resolution
end header


External --> Impact: load_requirements()
activate Impact
External --> Impact: filter_requirements_by_version()
== load_requirements() ==
Impact -> Impact: _get_requirements_config(config)
== filter_requirements_by_version() ==
Impact -> Config: parse_version(current_str)
Impact -> Config: compare_versions(parse_version(row.get(version_field, "v0.0.0")), current)
External <-- Impact: return Dict mapping requirement IDs to their display names, empty if unconfigured
deactivate Impact
External <-- Impact: return dict[str, dict[str, str]]
activate Impact
deactivate Impact

@enduml