@startuml REQ-IMPACT-001_Changed_function_detection_from_git_diff
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "Impact" as Impact
  participant "Parser" as Parser
end box

header
  **REQ-IMPACT-001: Changed function detection from git diff**
  //Description:// Cross-reference git diff line numbers with parsed functions\nto find changed functions
  //Acceptance Criteria:// Functions whose body lines overlap with git diff changed\nlines are reported as changed
end header


External --> Impact: collect_changed_functions()
activate Impact
== collect_changed_functions() ==
loop file_path in file_paths
Impact -> Impact: _collect_changed_lines(file_path, staged, diff_range, run_command)
alt changed_lines
end alt
end loop
== _extract_changed_functions() ==
Impact -> Parser: parse_source_file(file_path, config)
activate Parser
Impact <-- Parser: return list | None
deactivate Parser
deactivate Impact

@enduml