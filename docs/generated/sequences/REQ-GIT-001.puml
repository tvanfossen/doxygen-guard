@startuml REQ-GIT-001_Git_diff_parsing
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "User" as User

box "System" #LightBlue
  participant "Git" as Git
end box

header
  **REQ-GIT-001: Git diff parsing**
  //Description:// Parse unified diff output to extract changed line numbers
  //Acceptance Criteria:// Hunk headers parsed to 0-indexed line sets; pure deletions\nexcluded; git add supported
end header


User --> Git: get_branch_diff_range()
activate Git
User --> Git: get_changed_lines_for_file()
== get_branch_diff_range() ==
Git -> Git: get_merge_base(target_branch, run_command)
Git -> Git: _rev_parse_head(runner)
== get_changed_lines_for_file() ==
Git -> Git: get_staged_diff(file_path, run_command)
Git -> Git: parse_changed_lines(diff_output)
== get_merge_base() ==
group try
end group
group catch
note right: logger
end group
User <-- Git: return str | None
deactivate Git
User <-- Git: return set[int]
activate Git
deactivate Git

@enduml