@startuml REQ-PARSE-002 Doxygen block extraction
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "Ts Parser" as Ts_Parser

box "System" #LightBlue
  participant "Parser" as Parser
end box

header
  **REQ-PARSE-002: Doxygen block extraction**
  //Description:// Find and parse doxygen comment blocks immediately before\nfunction definitions using tree-sitter AST sibling detection\nwith regex fallback
  //Acceptance Criteria:// Doxygen blocks associated with correct functions including\nC++ template functions; tree-sitter prev_sibling handles\ntemplate_declaration and decorated_definition wrappers; all\ntags parsed including multi-tag single lines
end header


loop raw_line in block_text.splitlines()
loop segment in _split_inline_tags(line)
alt match
Parser -> Parser: _finalize_tag(tags, current_tag, current_value)
else
Parser -> Parser: _finalize_tag(tags, current_tag, current_value)
end alt
end loop
end loop
Parser -> Parser: _finalize_tag(tags, current_tag, current_value)
== find_doxygen_block_before() ==
group try
end group
group catch
note right: logger
end group
Parser -> Parser: _skip_blanks_and_attrs(lines, func_line)
Parser -> Parser: _scan_for_comment_start(lines, scan_line, start_re)
== _resolve_function_node() ==
Parser -> Ts_Parser: _unwrap_decorated(child)
== _find_preceding_doxygen() ==
Parser -> Ts_Parser: _collect_python_comments(prev, spec)
Parser -> Ts_Parser: _collect_c_comment(prev, spec)
Parser -> Parser: parse_doxygen_tags(raw)

@enduml