@startuml REQ-IMPACT-003_Impact_report_generation
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "User" as User

box "System" #LightBlue
  participant "Impact" as Impact
end box

header
  **REQ-IMPACT-003: Impact report generation**
  //Description:// Group changed functions by requirement and render as\nmarkdown/JSON/text
  //Acceptance Criteria:// Impact report lists affected requirements with their changed\nfunctions
end header


User --> Impact: _run_impact_command()
activate Impact
== _run_impact_command() ==
Impact -> Impact: run_impact(file_paths=file_paths, config=config, staged=args.staged, diff_range=args.diff_range,)
== run_impact() ==
Impact -> Impact: build_impact_report(changed, config)
Impact -> Impact: format_report(entries, config)
User <-- Impact: return Exit code: 0 on success, 1 if output path is invalid
deactivate Impact

@enduml