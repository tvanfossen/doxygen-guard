@startuml REQ-CONFIG-001_YAML_config_loading_and_merging
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "Config" as Config
end box

header
  **REQ-CONFIG-001: YAML config loading and merging**
  //Description:// Load .doxygen-guard.yaml and deep-merge with built-in\ndefaults
  //Acceptance Criteria:// User config overrides defaults; missing keys retain\ndefaults; invalid keys rejected
end header


External --> Config: load_config()
activate Config
== validate_config_schema() ==
Config -> Config: _validate_node(user_config, CONFIG_SCHEMA, "")
== load_config() ==
alt not config_path.exists()
Config -> Config: deep_merge(CONFIG_DEFAULTS, {})
end alt
alt not isinstance(user_config, dict)
Config -> Config: deep_merge(CONFIG_DEFAULTS, {})
end alt
Config -> Config: validate_config_schema(user_config)
Config -> Config: deep_merge(CONFIG_DEFAULTS, user_config)
Config -> Config: _validate_trace_options(merged)
deactivate Config

@enduml