@startuml REQ-TRACE-003_External_participant_prefix_routing
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "User" as User

box "System" #LightBlue
  participant "Trace" as Trace
end box

header
  **REQ-TRACE-003: External participant prefix routing**
  //Description:// Route unhandled events to external participants by event\nprefix
  //Acceptance Criteria:// Events matching receives_prefix of an external participant\nproduce edges to that participant
end header


User --> Trace: _load_external_participants()
activate Trace
== resolve_by_prefix() ==
User <-- Trace: return List of Participant objects declared as external in config
deactivate Trace

@enduml