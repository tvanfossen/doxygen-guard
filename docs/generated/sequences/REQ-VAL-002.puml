@startuml REQ-VAL-002 Version staleness detection
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "external" as external

box "System" #LightBlue
  participant "Validate" as Validate
end box

header
  **REQ-VAL-002: Version staleness detection**
  //Description:// Detect when function body changes but version tag is not\nupdated
  //Acceptance Criteria:// Modified function body without version tag change produces\nstaleness violation
end header

note over Validate: check_version_staleness()
note over Validate: check_version_staleness()

Validate -> external: get_validate()
activate external
external --> Validate: return
deactivate external
loop
Validate -> external: splitlines()
activate external
external --> Validate: return
deactivate external
Validate -> external: any()
activate external
external --> Validate: return
deactivate external
alt not version_line_changed
end alt
Validate -> external: get()
activate external
external --> Validate: return
deactivate external
alt marker_match and marker_match.group(1) != "reviewe
end alt
end loop

@enduml