@startuml REQ-VAL-002_Version_staleness_detection
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "User" as User

box "System" #LightBlue
  participant "Validate" as Validate
  participant "Config" as Config
end box

header
  **REQ-VAL-002: Version staleness detection**
  //Description:// Detect when function body changes but version tag is not\nupdated
  //Acceptance Criteria:// Modified function body without version tag change produces\nstaleness violation
end header


User --> Validate: check_version_staleness()
activate Validate
== check_version_staleness() ==
Validate -> Config: get_validate(config)
User <-- Validate: return list[Violation]
deactivate Validate

@enduml