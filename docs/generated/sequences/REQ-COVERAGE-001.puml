@startuml REQ-COVERAGE-001_Requirement_coverage_analysis
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

box "System" #LightBlue
  participant "Coverage" as Coverage
  participant "Trace" as Trace
end box

header
  **REQ-COVERAGE-001: Requirement coverage analysis**
  //Description:// Analyze and report requirement coverage across all tagged\nfunctions in source directories
  //Acceptance Criteria:// Requirements categorized as covered uncovered supports-only\nor orphan; unmapped functions identified; reports in text\nJSON and markdown formats; exit code 1 when gaps exist
end header

note over Coverage: _collect_supports_only() supports (no @req)., tags

Coverage -> Trace: collect_all_tagged_functions(source_dirs, config, full_reqs)
activate Trace
Trace <-- Coverage: return tuple[list[TaggedFunction], list[Participant], dict]
deactivate Trace
Coverage -> Coverage: _collect_req_ids(all_tagged)
Coverage -> Coverage: _collect_supports_only(all_tagged)
Coverage -> Coverage: _collect_unmapped_functions(all_tagged)
== run_coverage() ==
Coverage -> Coverage: analyze_coverage(source_dirs, config)

@enduml