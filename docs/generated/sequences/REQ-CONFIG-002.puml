@startuml REQ-CONFIG-002_Per-language_parse_settings
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "Config" as Config
end box

header
  **REQ-CONFIG-002: Per-language parse settings**
  //Description:// Resolve comment style and body detection per language from\nconfig
  //Acceptance Criteria:// Each language gets correct comment start/end patterns and\nbody style (braces vs indent)
end header


External --> Config: get_language_config()
activate Config
External --> Config: resolve_parse_settings()
== resolve_parse_settings() ==
External <-- Config: return Language config dict, or None if no language matches the file extension
deactivate Config
External <-- Config: return ParseSettings with comment style and body detection mode
activate Config
deactivate Config

@enduml