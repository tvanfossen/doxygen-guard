@startuml REQ-VAL-003 Tag syntax validation
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

box "System" #LightBlue
  participant "Validate" as Validate
  participant "Config" as Config
end box

header
  **REQ-VAL-003: Tag syntax validation**
  //Description:// Validate doxygen tag values against configured patterns and\nprefixes
  //Acceptance Criteria:// Tag values not matching configured pattern or prefix produce\ntag violations
end header


Validate -> Config: get_validate(config)
loop func in functions
loop tag_name, rules in tag_rules.items()
loop value in tag_values
end loop
end loop
end loop

@enduml