@startuml REQ-VAL-001_Doxygen_presence_check
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

box "System" #LightBlue
  participant "Validate" as Validate
  participant "Config" as Config
  participant "Git" as Git
  participant "Impact" as Impact
  participant "  Init  " as __Init__
end box

header
  **REQ-VAL-001: Doxygen presence check**
  //Description:// Every function must have a doxygen comment with brief and\nversion tags
  //Acceptance Criteria:// Undocumented functions produce presence violations;\ndocumented functions pass clean
end header


== validate_file() ==
Validate -> Config: parse_source_file(file_path, config, skip_forward_declarations=skip_fwd)
Validate -> Git: get_changed_lines_for_file(file_path)
== run_precommit() ==
Validate -> Git: get_branch_diff_range()
Validate -> Impact: collect_changed_functions(file_paths, config, diff_range=diff_range)
Validate -> Impact: collect_changed_functions(file_paths, config, staged=True)
Validate -> Impact: build_impact_report(changed, config)
Validate -> Impact: format_markdown(entries)
Validate -> Impact: format_markdown(entries)
Validate -> Impact: format_json(entries)
Validate -> __Init__: run_trace(source_dirs=source_dirs, config=config, trace_all=True)

@enduml