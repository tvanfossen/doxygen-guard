@startuml REQ-VAL-001 Doxygen presence check
autonumber

box "System" #LightBlue
  participant "Validate" as Validate
  participant "Parser" as Parser
  participant "Git" as Git
  participant "Config" as Config
  participant "Impact" as Impact
  participant "Trace" as Trace
end box

header
  **REQ-VAL-001: Doxygen presence check**
  //Description:// Every function must have a doxygen comment with brief and version tags
  //Acceptance Criteria:// Undocumented functions produce presence violations; documented functions pass clean
end header

note over Validate: validate_file()
note over Validate: run_validate()
note over Validate: run_precommit()

Validate -> Validate: check_presence()
Validate -> Validate: check_req_coverage()
Validate -> Validate: check_version_staleness()
Validate -> Validate: check_tags()
Validate -> Parser: parse_source_file()
Validate -> Git: get_changed_lines_for_file()
Validate -> Config: validate_output_path()
Validate -> Git: git_add()
Validate -> Impact: collect_changed_functions()
Validate -> Impact: build_impact_report()
Validate -> Impact: format_markdown()
Validate -> Impact: format_json()
Validate -> Trace: run_trace()

@enduml