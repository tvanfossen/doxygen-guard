@startuml REQ-0252
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External
entity "startMqttConnection" as startMqttConnection
entity "Pairing_Start" as Pairing_Start
entity "WiFi_ConnectAfterDelay" as WiFi_ConnectAfterDelay
entity "ContinuePairing" as ContinuePairing

box "System" #LightBlue
end box


External --> startMqttConnection: EVENT:EVENT_MQTT_START_CONNECTION\nstartMqttConnection()
activate startMqttConnection
== startMqttConnection() ==
== Pairing_Start() ==
note right of Pairing_Start: CLOUD_DISABLE
Pairing_Start --> WiFi_ConnectAfterDelay: EVENT:PAIRING_STARTED\nPairing_Start() -> WiFi_ConnectAfterDelay()
WiFi_ConnectAfterDelay --> ContinuePairing: EVENT:WIFI_IP_ACQUIRED\nWiFi_ConnectAfterDelay() -> ContinuePairing()
ContinuePairing --> ContinuePairing: EVENT:MQTT_START_CONNECTION

@enduml